# TerroirOS Watch local environment
# Copy this file to .env.local and fill in your values.

# Optional path for the local SQLite database file.
# Defaults to ./watch.db when omitted.
# Relative paths resolve from the repo root.
WATCH_DB_PATH=watch.db

# Optional toggle for local development.
# true  = always use mock analysis, even if OPENAI_API_KEY is set
# false = require OPENAI_API_KEY for live analysis
# empty = auto-detect; mock mode is enabled when OPENAI_API_KEY is missing
WATCH_USE_MOCK_AI=true

# Optional for local bootstrapping. Only required when WATCH_USE_MOCK_AI=false.
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=
