# TerroirOS Watch - Environment Variables
# Copy this file to .env.local and fill in the values you need.

# Persistence mode: "sqlite" (default) or "postgres"
WATCH_PERSISTENCE_MODE=sqlite

# SQLite path used when WATCH_PERSISTENCE_MODE=sqlite
WATCH_DB_PATH=./watch.db

# PostgreSQL connection string used when WATCH_PERSISTENCE_MODE=postgres
# Example: postgres://user:password@host:5432/terroiros_watch
DATABASE_URL=

# OpenAI configuration
# OPENAI_API_KEY is optional when WATCH_USE_MOCK_AI=true or omitted.
OPENAI_API_KEY=
WATCH_USE_MOCK_AI=true
WATCH_OPENAI_MODEL=gpt-4o

# Upload handling
WATCH_UPLOAD_DIR=./uploads
WATCH_UPLOAD_PUBLIC_BASE=/uploads
WATCH_MAX_DOCUMENTS=5
WATCH_MAX_UPLOAD_BYTES=10485760
WATCH_ALLOWED_UPLOAD_MIME_TYPES=application/pdf,application/json
