{
  "name": "terroiros-shield",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "node scripts/run-tests.mjs",
    "typecheck": "node node_modules/typescript/bin/tsc --noEmit",
    "check:env": "node scripts/check-env.mjs",
    "setup:db": "node scripts/setup-db.mjs",
